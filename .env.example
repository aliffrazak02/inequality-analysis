# Google Cloud BigQuery Configuration
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=inequality_analysis   # optional — this is the default
GCP_LOCATION=US                     # optional — this is the default

# Authentication — choose one:
# Option 1: Path to a service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Option 2: Use `gcloud auth application-default login` and leave the line above commented out
